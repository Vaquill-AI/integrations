# ============================================================
# Vaquill Chat Widget — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Required -----------------------------------------------

# Your Vaquill API key (starts with vq_key_...)
VAQUILL_API_KEY=vq_key_your_key_here

# ---- Optional -----------------------------------------------

# Vaquill API base URL (default: production)
VAQUILL_API_URL=https://api.vaquill.ai/api/v1

# Default RAG mode: "standard" or "deep"
# standard — faster, uses 18 techniques
# deep     — thorough, uses 35 techniques (costs more credits)
WIDGET_MODE=standard

# Title shown in the chat widget header
WIDGET_TITLE=Vaquill Legal AI

# Host port the container is exposed on (default: 8000)
HOST_PORT=8000

# CORS origins — comma-separated list, or * to allow all
# Examples:
#   ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com
#   ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=*
