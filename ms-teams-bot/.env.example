# Microsoft Teams Bot Registration
TEAMS_APP_ID=your-bot-app-id
TEAMS_APP_PASSWORD=your-bot-app-password
TEAMS_APP_TYPE=MultiTenant
# TEAMS_TENANT_ID=your-tenant-id  # Required for SingleTenant

# Vaquill API
VAQUILL_API_KEY=vq_key_...
VAQUILL_API_URL=https://api.vaquill.ai/api/v1
VAQUILL_MODE=standard
# VAQUILL_COUNTRY_CODE=IN

# Rate Limiting
RATE_LIMIT_PER_USER=20
RATE_LIMIT_PER_CHANNEL=100
RATE_LIMIT_PER_TENANT=500

# Redis (optional -- falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0
# REDIS_SSL=false

# Bot Behavior
SHOW_SOURCES=true
MAX_SOURCES=5
ENABLE_THREADING=true
ENABLE_ADAPTIVE_CARDS=true
ENABLE_CONVERSATION_HISTORY=true
MAX_CONTEXT_MESSAGES=10
RESPONSE_TIMEOUT=60

# Security
# ALLOWED_TENANTS=tenant-id-1,tenant-id-2
# ALLOWED_CHANNELS=channel-id-1,channel-id-2
# BLOCKED_USERS=user-id-1,user-id-2
REQUIRE_MENTION_IN_CHANNELS=true

# Server
PORT=3978
HOST=0.0.0.0
LOG_LEVEL=INFO
