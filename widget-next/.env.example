# =============================================
# Vaquill Widget — Environment Variables
# =============================================

# Required: your Vaquill API key (starts with vq_key_)
VAQUILL_API_KEY=vq_key_...

# Optional: override the default Vaquill API base URL
VAQUILL_API_URL=https://api.vaquill.ai/api/v1

# =============================================
# Widget UI
# =============================================

# Default query mode: standard | deep
NEXT_PUBLIC_DEFAULT_MODE=standard

# Default theme: dark | light
NEXT_PUBLIC_THEME=dark

# Widget display name shown in the header
NEXT_PUBLIC_AGENT_NAME=Vaquill Legal Assistant

# =============================================
# Optional TTS (text-to-speech via OpenAI)
# Leave blank to disable TTS
# =============================================
OPENAI_API_KEY=

# TTS model  (default: tts-1)
OPENAI_TTS_MODEL=tts-1

# TTS voice  (default: nova)
OPENAI_TTS_VOICE=nova

# =============================================
# Optional STT (speech-to-text via OpenAI)
# Requires OPENAI_API_KEY above
# =============================================
STT_MODEL=gpt-4o-mini-transcribe
