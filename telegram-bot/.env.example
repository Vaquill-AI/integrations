# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Vaquill API
VAQUILL_API_KEY=vq_key_...
VAQUILL_API_URL=https://api.vaquill.ai/api/v1
VAQUILL_MODE=standard
# VAQUILL_COUNTRY_CODE=IN

# Rate limiting
RATE_LIMIT_PER_USER_PER_DAY=100
RATE_LIMIT_PER_USER_PER_MINUTE=5

# Security (optional, comma-separated Telegram user IDs)
# ALLOWED_USERS=123456,789012

# Bot behaviour
MAX_MESSAGE_LENGTH=4000
MAX_CONVERSATION_HISTORY=10
MAX_SOURCES_PER_RESPONSE=5

# Observability
LOG_LEVEL=INFO
# SENTRY_DSN=

ENVIRONMENT=development
