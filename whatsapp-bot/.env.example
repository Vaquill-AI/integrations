# Vaquill API
VAQUILL_API_KEY=vq_key_...
VAQUILL_API_URL=https://api.vaquill.ai/api/v1
VAQUILL_MODE=standard
VAQUILL_COUNTRY_CODE=IN

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Rate limiting
RATE_LIMIT_DAILY=100
RATE_LIMIT_MINUTE=5
RATE_LIMIT_HOUR=30

# Security (comma-separated phone numbers, leave empty to allow all)
ALLOWED_NUMBERS=
BLOCKED_NUMBERS=
MAX_MESSAGE_LENGTH=1000

# Redis (optional — omit to use in-memory fallback)
# REDIS_URL=redis://localhost:6379/0

# Admin
ADMIN_API_KEY=your-admin-api-key
# ADMIN_NUMBERS=+919876543210

# Features
ENABLE_THINKING_MESSAGE=false
ENABLE_MEDIA_RESPONSES=true

# Session
SESSION_TIMEOUT_MINUTES=30
SESSION_CONTEXT_MESSAGES=10

# Server
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
