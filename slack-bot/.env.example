# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token  # Optional, for Socket Mode

# Vaquill API
VAQUILL_API_KEY=vq_key_your-api-key
VAQUILL_API_URL=https://api.vaquill.ai/api/v1
VAQUILL_MODE=standard
VAQUILL_COUNTRY_CODE=IN

# Rate Limiting
RATE_LIMIT_PER_USER=20
RATE_LIMIT_PER_CHANNEL=100

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Bot Behaviour
MAX_MESSAGE_LENGTH=4000
SHOW_SOURCES=true
ENABLE_THREADING=true

# Security (optional, comma-separated)
ALLOWED_CHANNELS=
BLOCKED_USERS=

# Logging
LOG_LEVEL=INFO

# Analytics (optional)
ENABLE_ANALYTICS=true
ANALYTICS_ENDPOINT=

# Server
PORT=3000
